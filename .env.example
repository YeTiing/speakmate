# Optional integrations. The app still runs without these keys.

# LLM dialogue provider. Keep this server-side; never expose it in frontend code.
# DeepSeek is OpenAI-compatible, so the same /chat/completions proxy works.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional OpenAI-compatible fallback variable names.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Professional pronunciation assessment provider.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Local API server port.
# Use 0.0.0.0 only when you want other devices on the LAN to access the packaged app.
API_HOST=127.0.0.1
API_PORT=8787
